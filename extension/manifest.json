{
  "manifest_version": 3,
  "name": "Midea PortaSplit Finder",
  "version": "1.0.0",
  "description": "一键查看 Midea PortaSplit 空调在 OBI、Amazon、MediaMarkt 等 13 家德国零售商的库存状态。自动检测有货/售罄，一鍵直达购买页面。",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon.png"
  }
}
